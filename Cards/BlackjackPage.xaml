<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Cards.BlackjackPage"
    xmlns:model="using:Cards.Models"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cards"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:ReverseBooleanVisibilityConverter x:Key="Reverse"/>
    </Page.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="AddPlayerRow" Height="Auto"/>
            <RowDefinition x:Name="ROG" Height="*"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical">
            <TextBox Name="ChipsBox" TextChanged="TextBox_TextChanged" Text="{x:Bind Text, Mode=TwoWay}" PlaceholderText="Player's chips" Visibility="{x:Bind game.BeforeStart, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            <Button Content="Add player" Command="{x:Bind AddPlayerCommand}" Visibility="{x:Bind game.BeforeStart, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            <Button Content="Start game" Command="{x:Bind StartGameCommand}" Visibility="{x:Bind game.BeforeStart, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,5,5,5"/>
            <Button Content="Continue" Click="ContinueGame_Click" Visibility="{x:Bind game.Over, Mode=OneWay}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,5,5,5"/>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical">
            <ItemsControl ItemsSource="{x:Bind game.Dealer.CardImages, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="ImageSource">
                        <Image Source="{x:Bind}" Height = "201" Width = "150" Margin="3,3,3,3"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{x:Bind game.Dealer.CardScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5,5,5,5" HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Visibility="{x:Bind game.Dealer.CanChangeBet, Mode=OneWay, Converter={StaticResource Reverse}}"/>
        </StackPanel>
        
        <ItemsControl ItemsSource="{x:Bind game.HandsListForUI, Mode=OneWay}" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="model:Generic">
                    <StackPanel Orientation="Vertical" Margin="10,0,10,0" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ItemsControl ItemsSource="{x:Bind CardImages, Mode=OneWay}" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="ImageSource">
                                        <Image Source="{x:Bind}" Height = "201" Width = "150" Margin="3,3,3,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{x:Bind CardScore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" Visibility="{x:Bind CanChangeBet, Mode=OneWay, Converter={StaticResource Reverse}}"/>
                        </Grid>
                        <Button Content="Hit" Command="{x:Bind HitCommand}" CommandParameter="{x:Bind Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <Button Content="Double Down" Command="{x:Bind DoubleDownCommand}" CommandParameter="{x:Bind Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <Button Content="Stand" Command="{x:Bind StandCommand}" CommandParameter="{x:Bind Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <Button Content="Surrender" Command="{x:Bind SurrenderCommand}" CommandParameter="{x:Bind Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <Button Content="Insure" Command="{x:Bind InsureCommand}" CommandParameter="{x:Bind Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <Button Content="Split" Command="{x:Bind SplitCommand}" CommandParameter="{x:Bind Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Bind Chips, Mode=TwoWay}" Visibility="{x:Bind ChipsBoxVisibility}" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBox Text="{x:Bind Bet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" LostFocus="TextBox_LostFocus" TextChanged="TextBox_TextChanged" 
                                     Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" IsEnabled="{x:Bind CanChangeBet, Mode=OneWay}"/>
                        </Grid>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
